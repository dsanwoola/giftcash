# Gift Cash — Firebase web config.
# Copy to .env.local and fill in from:
#   Firebase Console → Project settings → Your apps → Web app → SDK setup.
# Until these are set, the app runs in DEMO mode on local seed data.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Server-side Admin SDK (NEVER prefixed NEXT_PUBLIC) ---
# Used by the /api routes for privileged, ledger-affecting operations.
# From Firebase Console → Project settings → Service accounts → Generate key.
# Keep the literal "\n" escapes in the private key on a single line.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
